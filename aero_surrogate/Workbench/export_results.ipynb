# === USER SETTINGS ===
output_folder = r"C:\Users\dipes\OneDrive\Documents\Machine Learning\Python\Structural Optimization\aero_surrogate\fea_results"
csv_name       = "fea_results.csv"
import os
from Ansys.Mechanical.DataModel.Enums import DataModelObjectCategory

model    = ExtAPI.DataModel.Project.Model
analysis = model.Analyses[0]
solution = analysis.Solution

solution.EvaluateAllResults()

# case_label will be injected by the Workbench journal.
# Fallback to UNKNOWN_CASE if not injected.
try:
    case_label
except NameError:
    case_label = "UNKNOWN_CASE"


# Update results
solution.EvaluateAllResults()

# --- Get Max Stress ---
max_stress_res = None
for child in solution.Children:
    if child.Name == "Max_Stress":
        max_stress_res = child

if max_stress_res is None:
    raise Exception("Could not find Max_Stress result.")

max_stress = max_stress_res.Maximum


bodies = Model.Geometry.GetChildren(DataModelObjectCategory.Body, True) 
for body in bodies: volume= body.Volume
mass= body.Mass



# --- Get Material Density (robust version) ---
density = None
for mat in model.Materials.Children:
    if "steel" in mat.Name.lower():
        for prop in mat.Properties:
            if "density" in prop.Name.lower():
                density = prop.Value
                break
        if density is not None:
            break

if density is None:
    density = 7850.0   # fallback
    ExtAPI.Log.WriteMessage("WARNING: Using fallback density = 7850 kg/m^3")




# --- Write CSV ---
if not os.path.isdir(output_folder):
    os.makedirs(output_folder)

csv_path = os.path.join(output_folder, csv_name)

header = "case,max_stress_Pa,volume_m3,mass_kg\n"
line   = "{0},{1},{2},{3}\n".format(case_label, max_stress, volume, mass)

write_header = not os.path.isfile(csv_path)

with open(csv_path, "a") as f:
    if write_header:
        f.write(header)
    f.write(line)

ExtAPI.Log.WriteMessage("WROTE: case={}, volume={} m^3, mass={} kg".format(case_label, volume, mass))
